{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "rootDir": ".",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["GT1", "src", "types"],
  "exclude": ["node_modules", "dist"]
}
